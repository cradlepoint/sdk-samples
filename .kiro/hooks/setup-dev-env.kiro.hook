{
  "enabled": true,
  "name": "Setup Dev Environment",
  "description": "Creates a .venv virtual environment, installs all Python dependencies, and activates the venv. macOS/Linux: python3 make.py setup && source .venv/bin/activate. Windows: python make.py setup && .venv\\Scripts\\activate",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "python3 make.py setup || python make.py setup"
  }
}