{
  "name": "Setup Dev Environment",
  "version": "1.0.0",
  "description": "Creates a Python virtual environment and installs all SDK dependencies from requirements.txt",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "python3 make.py setup 2>/dev/null || python make.py setup"
  }
}