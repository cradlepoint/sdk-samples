{
  "enabled": true,
  "name": "Setup Dev Environment",
  "description": "Creates a .venv virtual environment and installs all Python dependencies. macOS/Linux: python3 setup_env.py. Windows: python setup_env.py",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "python3 setup_env.py || python setup_env.py"
  }
}