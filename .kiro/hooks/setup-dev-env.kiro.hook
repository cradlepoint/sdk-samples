{
  "name": "Setup Dev Environment",
  "version": "1.0.0",
  "description": "Automatically creates a Python virtual environment and installs SDK dependencies if .venv is missing",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "runCommand",
    "command": "test -d .venv || (python3 make.py setup || python make.py setup)"
  }
}