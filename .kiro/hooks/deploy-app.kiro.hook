{
  "enabled": true,
  "name": "Deploy App",
  "description": "One-click deploy of the current SDK app to the router via deploy.sh",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Read sdk_settings.ini to get the app_name, then run: bash deploy.sh <app_name>. Check the output for errors and verify the app started successfully by reviewing log timestamps."
  }
}